# Copy this file to a .env at the repo root (where docker-compose.prod.yml lives).
# docker compose reads variables from the root .env file at build/up time.

NODE_ENV=production

# Generate with: openssl rand -hex 64
# Must be at least 32 characters and NOT the dev default.
JWT_SECRET=

# Postgres credentials — password must be strong in production
POSTGRES_USER=battleships
POSTGRES_PASSWORD=
POSTGRES_DB=battleships

# Public HTTPS URL where the game is served (used for CORS + Socket.IO origin)
# Example: https://battleships.yourdomain.com
CLIENT_URL=

# Host port for the client container (Caddy/Nginx in front forwards 443 -> this)
HOST_HTTP_PORT=80

# Optional: token that guards admin endpoints (season creation, etc.)
ADMIN_TOKEN=
