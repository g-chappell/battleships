# Client environment variables
#
# Copy to .env.local for dev overrides, or set via Docker build args in production.
# These are read at BUILD TIME by Vite — changing them requires a rebuild.

# REST API base URL including /api path
VITE_API_URL=http://localhost:3001/api

# Socket.IO origin (without /api path)
VITE_SOCKET_URL=http://localhost:3001
