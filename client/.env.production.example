# Production env values are typically injected via Docker build ARGs,
# not read from a .env file — see client/Dockerfile. This file exists
# so that anyone running `npm run build --workspace=client` locally can
# copy it to .env.production to override the dev defaults.
#
# For a containerized prod deployment, leave the Docker build args as
# VITE_API_URL=/api and VITE_SOCKET_URL=/ so the client uses relative
# URLs that nginx proxies to the server container.

VITE_API_URL=/api
VITE_SOCKET_URL=/
